  <bpmn:collaboration id="Collaboration_0zafz3y">
    <bpmn:participant id="Participant_16o7kai" name="FirstLeadsProcess" processRef="Process_0c6ilns" />
    <bpmn:participant id="Participant_0t0gwy2" name="Диалог с клиентом" />
    <bpmn:messageFlow id="Flow_1t92yu5" sourceRef="Activity_1la04hb" targetRef="Participant_0t0gwy2" />
    <bpmn:messageFlow id="Flow_1q7czdg" sourceRef="Participant_0t0gwy2" targetRef="Activity_1s9e203" />
    <bpmn:messageFlow id="Flow_1inpwml" sourceRef="Activity_1f3xn1c" targetRef="Participant_0t0gwy2" />
    <bpmn:messageFlow id="Flow_0be9ymr" sourceRef="Participant_0t0gwy2" targetRef="Activity_1bvaj4m" />
    <bpmn:messageFlow id="Flow_02w1gcs" sourceRef="Activity_1a4mye3" targetRef="Participant_0t0gwy2" />
    <bpmn:messageFlow id="Flow_14vdn0p" sourceRef="Participant_0t0gwy2" targetRef="Activity_049jclq" />
    <bpmn:textAnnotation id="TextAnnotation_0osjcsu">
      <bpmn:text>This part MUST be easy. Just in general. The real GTM will be a bit later.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0r0b0t9">
      <bpmn:text>Этот репорт синхронизирует видение продукта с заказчиком</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_17rb82k">
      <bpmn:text>У нас глобально 3 задачи:
1. Получить ответ на Decision cards (для обогащения понимания)
2. Получить подтверждение видения продукта
3. Получить подтверждение корректности восприятия монетизационной модели</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11657xv">
      <bpmn:text>На самом деле порой принимают сразу</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1dkammo" associationDirection="None" sourceRef="Activity_02qavu7" targetRef="TextAnnotation_0r0b0t9" />
    <bpmn:association id="Association_14ik9jb" associationDirection="None" sourceRef="Activity_1f3xn1c" targetRef="TextAnnotation_17rb82k" />
    <bpmn:association id="Association_0mqfpf0" associationDirection="None" sourceRef="Event_1vl6ihg" targetRef="TextAnnotation_11657xv" />
    <bpmn:association id="Association_0935vpp" associationDirection="None" sourceRef="Activity_1svi0pk" targetRef="TextAnnotation_0osjcsu" />
    <bpmn:textAnnotation id="TextAnnotation_1u6169p">
      <bpmn:text>We will use it while personalizing the script</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_14qyhth" associationDirection="None" sourceRef="Activity_0jl4ynu" targetRef="TextAnnotation_1u6169p" />
    <bpmn:textAnnotation id="TextAnnotation_1hbkutr">
      <bpmn:text>На этом этапе должны быть решены все вопросы "что делать?"

Должны быть найдены компании, контакты, выбраны инструменты которыми мы будем решать задачу

Артефакт на выходе: просто обезьянья работа</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0jxhc2t" associationDirection="None" sourceRef="Activity_0333guf" targetRef="TextAnnotation_1hbkutr" />
  </bpmn:collaboration>
